generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  emoji       String?
  notes       String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  priority    String    @default("medium")
  category    String    @default("personal")

  parentId Int?
  parent   Task?  @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[] @relation("TaskSubtasks")

  eventId Int?   @unique
  event   Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id            Int       @id @default(autoincrement())
  title         String
  emoji         String?
  description   String?
  location      String?
  startTime     DateTime
  endTime       DateTime
  allDay        Boolean   @default(false)
  category      String    @default("personal")

  isRecurring   Boolean   @default(false)
  rrule         String?
  recurrenceEnd DateTime?

  googleEventId String?
  appleEventId  String?
  iCalUID       String?
  syncSource    String?
  lastSyncedAt  DateTime?

  task Task?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HealthMetric {
  id       Int      @id @default(autoincrement())
  type     String
  value    Float
  unit     String
  notes    String?
  loggedAt DateTime @default(now())
}

model HealthChatMessage {
  id        Int      @id @default(autoincrement())
  role      String
  content   String
  createdAt DateTime @default(now())
}

model PlaidItem {
  id          Int                @id @default(autoincrement())
  itemId      String             @unique
  accessToken String
  institution String?
  accounts    FinancialAccount[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model FinancialAccount {
  id             Int        @id @default(autoincrement())
  name           String
  type           String
  institution    String?
  balance        Float      @default(0)
  currency       String     @default("USD")
  isActive       Boolean    @default(true)
  notes          String?
  plaidAccountId String?    @unique
  plaidItemId    Int?
  plaidItem      PlaidItem? @relation(fields: [plaidItemId], references: [id], onDelete: SetNull)

  snapshots BalanceSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BalanceSnapshot {
  id         Int              @id @default(autoincrement())
  accountId  Int
  account    FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  balance    Float
  recordedAt DateTime         @default(now())
}

model FinanceChatMessage {
  id        Int      @id @default(autoincrement())
  role      String
  content   String
  createdAt DateTime @default(now())
}

model SupplementEntry {
  id        Int      @id @default(autoincrement())
  name      String
  amount    Float    @default(0)
  unit      String   @default("mg")
  notes     String?
  loggedAt  DateTime @default(now())
}

model DailySupplement {
  id        Int      @id @default(autoincrement())
  name      String
  amount    Float    @default(0)
  unit      String   @default("mg")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tracks which dates the daily stack has been auto-logged, so deletions survive a refresh
model DailyStackAutoLog {
  id        Int      @id @default(autoincrement())
  date      String   @unique // "YYYY-MM-DD"
  createdAt DateTime @default(now())
}

model WorkoutEntry {
  id       Int      @id @default(autoincrement())
  activity String
  minutes  Int
  notes    String?
  loggedAt DateTime @default(now())
}

model FinancialGoal {
  id            Int       @id @default(autoincrement())
  name          String
  emoji         String    @default("🎯")
  targetAmount  Float
  currentAmount Float     @default(0)
  targetDate    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
